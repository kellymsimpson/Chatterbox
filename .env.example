# Copy to .env.local (never commit secrets). Used by the frontend via Vite-less
# injection later, or set the same names in the Vercel project settings.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional — local/CI only for applying migrations (never expose to the browser):
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SUPABASE_DB_URL=postgresql://postgres:...@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
